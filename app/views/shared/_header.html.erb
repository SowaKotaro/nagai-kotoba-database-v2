<%# グローバルヘッダー(docs/design.md §5.1)。印章ロゴ + ナビ(現在地表示) + 常設のキーワード検索。
    狭幅ではナビ+検索をハンバーガーで開閉するサイドパネルに格納する(nav-drawer コントローラ)。 %>
<header class="site-header" data-controller="nav-drawer"
        data-nav-drawer-open-label-value="<%= t("layouts.menu_open") %>"
        data-nav-drawer-close-label-value="<%= t("layouts.menu_close") %>">
  <div class="site-header__inner">
    <%= link_to root_path, class: "site-brand" do %>
      <%# ブランド印章(落款)。インライン SVG なので色はトークンを参照できる %>
      <svg class="site-brand__seal" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <rect width="24" height="24" fill="var(--shu)"/>
        <text x="12" y="17.5" text-anchor="middle" font-size="14" font-family="serif" fill="var(--bg)">言</text>
      </svg>
      <span class="site-brand__name"><%= t("layouts.brand") %></span>
    <% end %>

    <button type="button" class="nav-toggle" aria-label="<%= t("layouts.menu_open") %>" aria-expanded="false"
            data-nav-drawer-target="button" data-action="nav-drawer#toggle">
      <span class="nav-toggle__bars" aria-hidden="true">
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </span>
    </button>

    <div class="site-header__right" data-nav-drawer-target="panel">
      <nav class="site-nav">
        <%= link_to t("layouts.nav.words"), words_path, class: ("is-current" if request.path == words_path) %>
        <%= link_to t("layouts.nav.search"), search_path, class: ("is-current" if request.path == search_path) %>
        <% if authenticated? %>
          <%= link_to t("layouts.nav.admin"), admin_root_path, class: ("is-current" if request.path.start_with?("/admin")) %>
          <%= button_to t("layouts.nav.logout"), session_path, method: :delete %>
        <% end %>
      </nav>

      <%# 常設のキーワード検索(下線1本。枠で囲わない)。Enter で単語一覧の絞り込みへ %>
      <%= form_with url: words_path, method: :get, class: "header-search" do %>
        <%= text_field_tag :q, nil, placeholder: t("layouts.search_placeholder"),
              class: "header-search__input", aria: { label: t("searches.q_label") } %>
        <button type="submit" class="header-search__submit" aria-label="<%= t("layouts.search_submit") %>"><%= icon "magnifying_glass" %></button>
      <% end %>
    </div>

    <div class="nav-drawer__scrim" data-nav-drawer-target="scrim" data-action="click->nav-drawer#close"></div>
  </div>
</header>
