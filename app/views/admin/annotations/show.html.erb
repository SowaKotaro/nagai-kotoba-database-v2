<% content_for :title, t("admin.annotations.title") %>
<%= turbo_frame_tag "annotation-console", data: { turbo_action: "advance" } do %>
  <div class="ann" data-controller="queue-nav">
    <div class="ann-bar">
      <span class="ann-bar__counter">
        <%= t("admin.annotations.remaining") %>
        <span class="rest"><%= @remaining %></span> <%= t("admin.annotations.unit_word") %>
      </span>
      <span class="ann-bar__legend" aria-hidden="true">
        <span><key>&#9166;</key><%= t("admin.annotations.save_next") %></span>
        <span><key>&rarr;</key><%= t("admin.annotations.skip") %></span>
        <span><key>&larr;</key><%= t("admin.annotations.back") %></span>
      </span>
    </div>

    <p class="ann-eyebrow"><span class="no">NO. <%= @word.id %></span><span><%= t("admin.annotations.eyebrow") %></span></p>
    <h1 class="ann-word"><%= @word.surface %></h1>
    <p class="ann-word-meta"><%= t("admin.annotations.char_type") %>　<%= @word.char_type_pattern %></p>

    <%# Claude の提案(Issue 38)。反映はリンク(GET)で行い、保存＝承認は下のフォームのみ %>
    <%= render "proposal", proposal: @proposal, word: @word if @proposal %>

    <%= form_with model: @word, url: admin_annotation_path(@word), method: :patch,
                  data: { queue_nav_target: "form" } do |form| %>
      <%# 「提案あり」フィルタ(?proposed=1)を保存後のキュー移動でも保つ %>
      <% if params[:proposed].present? %>
        <%= hidden_field_tag :proposed, params[:proposed] %>
      <% end %>
      <% if @word.errors.any? %>
        <div class="error-explanation">
          <h2><%= t("admin.annotations.error_header") %></h2>
          <ul>
            <% @word.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# 表層形の訂正(Issue 36: 編集画面をコンソールへ統合)。変更すると保存時に文字種も再生成される %>
      <div class="ann-surface">
        <label class="ann-surface__label" for="word_surface"><%= t("admin.annotations.surface") %></label>
        <%= form.text_area :surface, rows: 1, class: "ann-surface__input", id: "word_surface" %>
        <span class="ann-surface__note"><%= t("admin.annotations.surface_note") %></span>
      </div>

      <div class="ann-senses" data-controller="sense-cloner">
        <div data-sense-cloner-target="container">
          <%= form.fields_for :word_senses do |sense_form| %>
            <%= render "sense_fields", form: sense_form %>
          <% end %>
        </div>

        <button type="button" class="ann-add-sense" data-action="sense-cloner#add">
          <%= t("admin.annotations.add_sense") %>
          <small><%= t("admin.annotations.add_sense_hint") %></small>
        </button>
      </div>

      <div class="ann-actionbar">
        <%# スティッキー引き継ぎ(Issue 37): ON にすると直前に保存した語のジャンル・
            エンティティ・品詞・語種が次の語の初期値になる(同質な語群を流すとき用) %>
        <label class="ann-sticky" title="<%= t("admin.annotations.sticky_hint") %>">
          <%= check_box_tag :sticky, "1", session[:annotation_sticky], class: "ann-sticky__input" %>
          <%= t("admin.annotations.sticky") %>
        </label>
        <% if @prev_word %>
          <%= link_to t("admin.annotations.back"), admin_annotation_path(@prev_word, proposed: params[:proposed].presence),
                      class: "btn", data: { queue_nav_target: "back" } %>
        <% else %>
          <span class="btn" aria-disabled="true"><%= t("admin.annotations.back") %></span>
        <% end %>
        <span class="spacer"></span>
        <%= link_to t("admin.annotations.skip"),
                    (@skip_word ? admin_annotation_path(@skip_word, proposed: params[:proposed].presence)
                                : admin_annotations_path(proposed: params[:proposed].presence)),
                    class: "btn", data: { queue_nav_target: "skip" } %>
        <%# 保留: 同じフォームを hold へ送る。formnovalidate で必須チェックを外し、途中入力でも保留できる。
            hold アクションはフォーム内容を保存せず、状態だけ保留にしてキューから外す %>
        <%= form.submit t("admin.annotations.hold"), name: nil,
                    formaction: hold_admin_annotation_path(@word), formnovalidate: true,
                    class: "btn" %>
        <%= form.submit t("admin.annotations.save_next"), class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>
<% end %>
