<%# 1つの語義提案の内訳(意味・ジャンル・エンティティ・品詞・語種・別表記)。
    local: sense(AnnotationProposal::SenseProposal) / word / creatable。
    未知のマスタ名は新設候補(朱)で示し、creatable(単一語義)ならワンタップ作成ボタンにする(Issue 66)。 %>
<dl class="ann-proposal__grid">
  <% if sense.meaning %>
    <dt><%= t("admin.annotations.meaning") %></dt>
    <dd><%= sense.meaning %></dd>
  <% end %>

  <% if sense.reading %>
    <dt><%= t("admin.annotations.reading") %></dt>
    <dd><%= sense.reading %></dd>
  <% end %>

  <% if sense.genre_path.any? %>
    <dt><%= t("admin.annotations.genre") %></dt>
    <dd>
      <% sense.genre_path.each_with_index do |name, i| %>
        <% if i.positive? %><span class="sep">›</span><% end %><span><%= name %></span>
      <% end %>
      <%# 小分類だけ未登録でも、中分類まで既存の木で解決していればワンタップ作成できる %>
      <% unless sense.resolved_genre %>
        <%= render "new_master", field: "genre", word: word,
              creatable: creatable && sense.resolved_genre_chain.last&.medium?,
              label: t("admin.annotations.proposal.create_master") %>
      <% end %>
    </dd>
  <% end %>

  <% if sense.entity_type_name %>
    <dt><%= t("admin.annotations.entity") %></dt>
    <dd>
      <%= sense.entity_type_name %>
      <% unless sense.resolved_entity_type %>
        <%= render "new_master", field: "entity_type", word: word, creatable: creatable,
              label: t("admin.annotations.proposal.create_master") %>
      <% end %>
    </dd>
  <% end %>

  <% if sense.part_of_speech_name %>
    <dt><%= t("admin.annotations.pos") %></dt>
    <dd>
      <%= sense.part_of_speech_name %>
      <% unless sense.resolved_part_of_speech %>
        <%= render "new_master", field: "part_of_speech", word: word, creatable: creatable,
              label: t("admin.annotations.proposal.create_master") %>
      <% end %>
    </dd>
  <% end %>

  <% if sense.word_origin_names.any? %>
    <dt><%= t("admin.annotations.origins") %></dt>
    <dd>
      <%= sense.resolved_word_origins.map(&:name).join("・") %>
      <% sense.unknown_word_origin_names.each do |name| %>
        <% if creatable %>
          <%= render "new_master", field: "word_origin", word: word, creatable: true,
                label: t("admin.annotations.proposal.create_named_master", name: name), name: name %>
        <% else %>
          <%= name %><span class="ann-proposal__new"><%= t("admin.annotations.proposal.new_master") %></span>
        <% end %>
      <% end %>
    </dd>
  <% end %>

  <%# 言語的特徴(該当部分つき)。反映すると範囲タップ済みの状態でフォームに組まれる。
      マスタに無い特徴名は朱「新設候補」で示す(反映では組まれず、その場追加が要る)。 %>
  <% if sense.linguistic_features.any? %>
    <dt><%= t("admin.annotations.features") %></dt>
    <dd>
      <% sense.linguistic_features.each do |feature| %>
        <span class="ann-proposal__feature">
          <b><%= feature["name"] %></b>
          <span class="ann-proposal__feature-target"><%= feature["target"] %> / <%= feature["target_reading"] %></span>
          <% unless sense.resolved_linguistic_feature(feature) %>
            <span class="ann-proposal__new"><%= t("admin.annotations.proposal.new_master") %></span>
          <% end %>
        </span>
      <% end %>
    </dd>
  <% end %>

  <% if sense.variants.any? %>
    <dt><%= t("admin.annotations.variants") %></dt>
    <dd><%= sense.variants.map { |v| v["surface"] }.join("・") %></dd>
  <% end %>
</dl>
