<%# Claude の提案パネル(Issue 38)。提案値・confidence・判断メモを見せ、「提案を反映」で
    フォームに初期値として流し込む(保存＝承認は人間の操作のみ)。
    未知のマスタ名は新設候補(朱)として表示し、各行のその場追加で作ってから反映し直す。 %>
<div class="ann-proposal">
  <div class="ann-proposal__head">
    <span class="ann-proposal__title"><%= t("admin.annotations.proposal.title") %></span>
    <%# 反映済み/見送りの提案(注釈済みの語を見直しているとき)は状態を明示する %>
    <% unless proposal.pending? %>
      <span class="ann-proposal__status ann-proposal__status--<%= proposal.status %>">
        <%= t("admin.annotations.proposal.status.#{proposal.status}") %>
      </span>
    <% end %>
    <% if proposal.confidence %>
      <span class="ann-proposal__confidence ann-proposal__confidence--<%= proposal.confidence %>">
        <%= t("admin.annotations.proposal.confidence.#{proposal.confidence}",
              default: proposal.confidence) %>
      </span>
    <% end %>
    <%# 立項スコア(docs/annotation-guidelines.md §2)。3以下は朱でオーナー判断を促す %>
    <% if proposal.entry_score %>
      <span class="ann-proposal__entry <%= "ann-proposal__entry--concern" if proposal.entry_concern? %>">
        <%= t("admin.annotations.proposal.entry_score", score: proposal.entry_score) %>
      </span>
    <% end %>
    <span class="spacer"></span>
    <%= link_to t("admin.annotations.proposal.apply"),
          admin_annotation_path(word, nav_params.merge(apply_proposal: 1)),
          class: "btn btn--sm", data: { turbo_frame: "annotation-console" } %>
  </div>

  <%# 複数語義(同音異義語・Issue 41)は語義ごとに区切って見せる。単一なら見出しは付けない。
      新設候補のワンタップ作成(Issue 66)は再反映で全語義を組み直す都合上、単一語義のときだけ有効にする %>
  <% if proposal.multiple_senses? %>
    <p class="ann-proposal__senses-note"><%= t("admin.annotations.proposal.multiple_senses", count: proposal.senses.size) %></p>
    <% proposal.senses.each_with_index do |sense, i| %>
      <div class="ann-proposal__sense">
        <span class="ann-proposal__sense-no"><%= t("admin.words.senses_legend") %> <%= format("%02d", i + 1) %></span>
        <%= render "proposal_sense", sense: sense, word: word, creatable: false %>
      </div>
    <% end %>
  <% else %>
    <%= render "proposal_sense", sense: proposal.senses.first, word: word, creatable: true %>
  <% end %>

  <% if proposal.entry_notes %>
    <p class="ann-proposal__notes ann-proposal__notes--entry"><%= t("admin.annotations.proposal.entry_notes") %>　<%= proposal.entry_notes %></p>
  <% end %>
  <% if proposal.notes %>
    <p class="ann-proposal__notes"><%= t("admin.annotations.proposal.notes") %>　<%= proposal.notes %></p>
  <% end %>
</div>
