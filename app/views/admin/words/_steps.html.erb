<%# 一括登録のフェーズ表示。current(1〜3)が現在のステップ。 %>
<ol class="steps" aria-label="<%= t("admin.words.bulk.steps.aria") %>">
  <% t("admin.words.bulk.steps.labels").each_with_index do |label, i| %>
    <% step = i + 1 %>
    <li class="steps__item <%= "is-current" if step == current %> <%= "is-done" if step < current %>"
        aria-current="<%= "step" if step == current %>">
      <span class="steps__no"><%= step %></span>
      <span class="steps__label"><%= label %></span>
    </li>
  <% end %>
</ol>
