<%# ジャンルの大→中→小 依存ドロップダウン。local: form(語義のフォームビルダ)
    送信されるのは小分類(genre_id)のみ。大・中の select は name を持たせず UI 専用にする。 %>
<% current_genre = form.object.genre %>
<% ancestors = current_genre&.self_and_ancestors || [] %>
<% large_id = ancestors[0]&.id %>
<% medium_id = ancestors[1]&.id %>
<% small_id = ancestors[2]&.id %>

<span data-controller="genre-cascade" data-genre-cascade-url-value="<%= children_admin_genres_path %>">
  <select data-genre-cascade-target="large" data-action="change->genre-cascade#largeChanged">
    <option value=""></option>
    <% Genre.where(level: :large).order(:name).each do |genre| %>
      <option value="<%= genre.id %>" <%= "selected" if genre.id == large_id %>><%= genre.name %></option>
    <% end %>
  </select>

  <select data-genre-cascade-target="medium" data-action="change->genre-cascade#mediumChanged">
    <option value=""></option>
    <% if large_id %>
      <% Genre.where(parent_id: large_id).order(:name).each do |genre| %>
        <option value="<%= genre.id %>" <%= "selected" if genre.id == medium_id %>><%= genre.name %></option>
      <% end %>
    <% end %>
  </select>

  <%= form.select :genre_id,
        options_from_collection_for_select(
          medium_id ? Genre.where(parent_id: medium_id).order(:name) : [], :id, :name, small_id
        ),
        { include_blank: true },
        { "data-genre-cascade-target": "small" } %>
</span>
