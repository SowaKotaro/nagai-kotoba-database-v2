<%= form_with model: [ :admin, @word ] do |form| %>
  <% if @word.errors.any? %>
    <div class="error-explanation">
      <h2><%= t("admin.words.error_header") %></h2>
      <ul>
        <% @word.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :surface %>
    <%= form.text_field :surface %>
  </div>

  <fieldset data-controller="nested-form" data-nested-form-placeholder-value="NEW_SENSE">
    <legend><%= t("admin.words.senses_legend") %></legend>

    <div data-nested-form-target="container">
      <%= form.fields_for :word_senses do |sense_form| %>
        <%= render "word_sense_fields", form: sense_form %>
      <% end %>
    </div>

    <%# 新規語義のテンプレート(画面には出さず、JS で複製して挿入する) %>
    <template data-nested-form-target="template">
      <%= form.fields_for :word_senses, WordSense.new, child_index: "NEW_SENSE" do |sense_form| %>
        <%= render "word_sense_fields", form: sense_form %>
      <% end %>
    </template>

    <button type="button" data-action="nested-form#add"><%= t("admin.words.add_sense") %></button>
  </fieldset>

  <div>
    <%= form.submit %>
  </div>
<% end %>
