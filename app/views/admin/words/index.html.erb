<% content_for :title, t("admin.words.title") %>

<h1 class="page-title"><%= t("admin.words.title") %></h1>

<%# 検索(表層形・読みの部分一致)+タグ絞り込みと、注釈状態のタブ。
    タグのセレクトは選択で即送信(auto-submit)。同質な語群を一括適用パネルで
    まとめて付け替えるための入口になる(例: ジャンル「ことわざ」×品詞「普通名詞」→ 連語へ)。 %>
<div class="admin-words-toolbar">
  <%= form_with url: admin_words_path, method: :get, class: "admin-words-filter",
        data: { controller: "auto-submit" } do %>
    <% if @status %><%= hidden_field_tag :status, @status %><% end %>
    <div class="admin-words-search">
      <%= text_field_tag :q, @query, placeholder: t("admin.words.index.q_placeholder"),
            class: "admin-words-search__input", aria: { label: t("admin.words.index.q_label") } %>
      <button type="submit" class="admin-words-search__submit" aria-label="<%= t("admin.words.index.search") %>"><%= icon "magnifying_glass" %></button>
    </div>

    <div class="admin-words-tag-filters">
      <label class="admin-words-tag-filter">
        <span class="admin-words-tag-filter__label"><%= t("admin.words.index.filter_genre") %></span>
        <%= select_tag :genre_id,
              options_for_select(admin_genre_filter_options(@all_genres), @tag_filters[:genre_id]),
              include_blank: t("admin.words.index.filter_any"),
              data: { action: "change->auto-submit#submit" } %>
      </label>
      <label class="admin-words-tag-filter">
        <span class="admin-words-tag-filter__label"><%= t("admin.words.index.filter_pos") %></span>
        <%= select_tag :part_of_speech_id,
              options_from_collection_for_select(@parts_of_speech, :id, :name, @tag_filters[:part_of_speech_id]),
              include_blank: t("admin.words.index.filter_any"),
              data: { action: "change->auto-submit#submit" } %>
      </label>
      <label class="admin-words-tag-filter">
        <span class="admin-words-tag-filter__label"><%= t("admin.words.index.filter_entity") %></span>
        <%= select_tag :entity_type_id,
              options_from_collection_for_select(@entity_types, :id, :name, @tag_filters[:entity_type_id]),
              include_blank: t("admin.words.index.filter_any"),
              data: { action: "change->auto-submit#submit" } %>
      </label>
      <label class="admin-words-tag-filter">
        <span class="admin-words-tag-filter__label"><%= t("admin.words.index.filter_origin") %></span>
        <%= select_tag :word_origin_id,
              options_from_collection_for_select(@word_origins, :id, :name, @tag_filters[:word_origin_id]),
              include_blank: t("admin.words.index.filter_any"),
              data: { action: "change->auto-submit#submit" } %>
      </label>
      <% if @tag_filters.any? %>
        <%= link_to t("admin.words.index.filter_reset"),
              admin_words_path({ q: @query.presence, status: @status }.compact),
              class: "admin-words-tag-filter__reset" %>
      <% end %>
      <noscript><%= submit_tag t("admin.words.index.search"), class: "btn btn--sm" %></noscript>
    </div>
  <% end %>

  <nav class="admin-status-tabs" aria-label="<%= t("admin.words.index.status_label") %>">
    <% { nil => t("admin.words.index.status_all"),
         "annotation_pending" => t("admin.words.index.status_pending"),
         "annotation_on_hold" => t("admin.words.index.status_on_hold"),
         "annotation_done" => t("admin.words.index.status_done") }.each do |status, label| %>
      <%= link_to label, admin_words_path({ q: @query.presence, status: status }.merge(@tag_filters).compact),
            class: "admin-status-tabs__tab", "aria-current": (@status == status ? "page" : nil) %>
    <% end %>
  </nav>
</div>

<%# Claude Code 連携(Issue 38): 調査用データの書き出し → スキルで調査 → 提案 JSON の取り込み %>
<p class="admin-words-claude">
  <%= link_to t("admin.annotation_proposals.export.title"), export_admin_annotation_proposals_path %>
  <span class="sep">›</span>
  <%= link_to t("admin.annotation_proposals.new.title"), new_admin_annotation_proposal_path %>
  <span class="sep">›</span>
  <%= link_to t("admin.annotation_proposals.proposed_queue"), admin_annotations_path(proposed: 1) %>
</p>

<p class="admin-words-count"><%= t("admin.words.index.total", count: number_with_delimiter(@total_count)) %></p>

<% if @words.any? %>
  <%= render "bulk_annotation" %>

  <%# 狭幅ではテーブルを潰さず、この枠内で横スクロールさせる %>
  <div class="table-scroll" data-controller="check-all">
  <table class="data-table admin-words-table">
    <thead>
      <tr>
        <th class="admin-words-table__check">
          <input type="checkbox" aria-label="<%= t("admin.bulk_annotations.select_all") %>"
                 data-check-all-target="toggle" data-action="check-all#toggle">
        </th>
        <th><%= Word.human_attribute_name(:surface) %></th>
        <th><%= t("admin.words.index.col_reading") %></th>
        <th class="admin-words-table__num"><%= t("admin.words.senses_count") %></th>
        <th class="admin-words-table__status"><%= t("admin.words.index.col_status") %></th>
        <th class="admin-words-table__actions"></th>
      </tr>
    </thead>
    <tbody>
      <% @words.each do |word| %>
        <tr>
          <td class="admin-words-table__check">
            <%# フォームの外にあるため form 属性で一括適用フォームに紐づける %>
            <input type="checkbox" name="bulk_annotation[word_ids][]" value="<%= word.id %>"
                   form="bulk-annotation-form" aria-label="<%= t("admin.bulk_annotations.select_word", surface: word.surface) %>"
                   data-check-all-target="item" data-action="check-all#sync">
          </td>
          <td><%= link_to word.surface, admin_annotation_path(word), data: { turbo_frame: "_top" } %></td>
          <td class="admin-words-table__reading"><%= word.word_senses.map(&:reading).uniq.join("、") %></td>
          <td class="admin-words-table__num"><%= word.word_senses.size %></td>
          <td class="admin-words-table__status">
            <% if word.annotation_done? %>
              <span class="admin-words-table__annotated"><%= word.annotated_at.strftime("%Y-%m-%d") %></span>
            <% elsif word.annotation_on_hold? %>
              <span class="admin-words-table__on-hold"><%= t("admin.words.index.status_on_hold") %></span>
            <% else %>
              <span class="admin-words-table__unannotated"><%= t("admin.words.index.status_pending") %></span>
            <% end %>
          </td>
          <td class="admin-words-table__actions">
            <div class="actions actions--tight">
              <%= link_to admin_annotation_path(word), class: "btn btn--sm btn--icon",
                    title: t("admin.words.index.annotate_title") do %>
                <%= icon "pencil_simple" %><span><%= t("admin.words.index.annotate") %></span>
              <% end %>
              <%= button_to admin_word_path(word), method: :delete,
                    class: "btn btn--sm btn--icon",
                    title: t("admin.words.destroy_title"),
                    data: { turbo_confirm: t("admin.words.confirm_destroy") } do %>
                <%= icon "trash" %><span><%= t("admin.words.destroy") %></span>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>

  <nav class="pagination">
    <%# 検索・絞り込み条件を保持したままページ送りする %>
    <% base = request.query_parameters.except("page") %>
    <% if @page > 1 %>
      <%= link_to t("words.pagination.prev"), admin_words_path(base.merge(page: @page - 1)) %>
    <% end %>

    <span><%= t("words.pagination.status", page: @page, total: @total_pages) %></span>

    <% if @page < @total_pages %>
      <%= link_to t("words.pagination.next"), admin_words_path(base.merge(page: @page + 1)) %>
    <% end %>
  </nav>
<% else %>
  <p class="empty-note"><%= t("admin.words.index.empty") %></p>
<% end %>
