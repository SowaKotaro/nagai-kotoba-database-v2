<% content_for :title, t("admin.words.title") %>

<h1 class="page-title"><%= t("admin.words.title") %></h1>

<p><%= link_to t("admin.words.new"), new_admin_word_path, class: "btn btn--primary" %></p>

<table class="data-table">
  <thead>
    <tr>
      <th><%= Word.human_attribute_name(:surface) %></th>
      <th><%= t("admin.words.senses_count") %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @words.each do |word| %>
      <tr>
        <td><%= word.surface %></td>
        <td><%= word.word_senses.size %></td>
        <td>
          <div class="actions">
            <%= link_to t("admin.words.edit"), edit_admin_word_path(word), class: "btn btn--sm" %>
            <%= button_to t("admin.words.destroy"), admin_word_path(word), method: :delete,
                  class: "btn btn--sm",
                  data: { turbo_confirm: t("admin.words.confirm_destroy") } %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
