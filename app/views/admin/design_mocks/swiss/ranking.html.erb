<% max_crossing = mock_crossing_ranking.first.crossing %>
<% max_count = mock_distribution.map(&:last).max %>
<%= render "admin/design_mocks/swiss/head", current: :ranking %>

<section class="dm-swiss__rankhead">
  <span class="halfcircle"></span>
  <span class="dotline"></span>
  <h1>読みが長い順</h1>
  <p>収録 <%= mock_stats[:words] %> 語を読みの文字数で並べた記録。上位は成句と作品名がほとんどを占める。</p>
</section>

<div class="dm-swiss__bars">
  <div class="dm-swiss__kicker">Sort by</div>
  <div class="dm-swiss__kinds" style="margin-top: 14px">
    <% mock_ranking_kinds.each_with_index do |kind, index| %>
      <a class="dm-swiss__kind<%= " is-on" if index.zero? %>" href="#">
        <b><%= kind[:label] %></b>
        <span><%= kind[:note] %></span>
      </a>
    <% end %>
  </div>
</div>

<div class="dm-swiss__bars">
  <% mock_words.take(7).each_with_index do |word, index| %>
    <a class="dm-swiss__barrow" href="#">
      <span class="rk"><%= format("%02d", index + 1) %></span>
      <span class="nm"><%= word.surface %></span>
      <span class="tr"><i style="width: <%= (word.length / 16.0 * 100).round %>%"></i></span>
      <span class="vl"><%= word.length %></span>
    </a>
  <% end %>
</div>

<div class="dm-swiss__bars">
  <div class="dm-swiss__kicker">Ring crossings</div>
  <% mock_crossing_ranking.take(5).each_with_index do |word, index| %>
    <a class="dm-swiss__barrow" href="#">
      <span class="rk"><%= format("%02d", index + 1) %></span>
      <span class="nm"><%= word.surface %></span>
      <span class="tr"><i style="width: <%= (word.crossing.to_f / max_crossing * 100).round %>%"></i></span>
      <span class="vl"><%= word.crossing %></span>
    </a>
  <% end %>
</div>

<div class="dm-swiss__dist dm-swiss__grid">
  <div class="dm-swiss__vlabel">Distribution</div>
  <div class="dm-swiss__distchart">
    <% mock_distribution.each do |_length, count| %>
      <div class="<%= "is-low" if count < 50 %>">
        <b><%= count %></b>
        <i style="height: <%= (count.to_f / max_count * 86).round %>%"></i>
      </div>
    <% end %>
  </div>
  <div class="dm-swiss__distax">
    <% mock_distribution.each do |length, _count| %>
      <span><%= length %></span>
    <% end %>
  </div>

  <div class="dm-swiss__vlabel" style="margin-top: 40px">Method</div>
  <p class="dm-swiss__note" style="grid-column: 3 / 13; margin-top: 40px">
    <b>読みの文字数</b>はカタカナ表記の字数で、長音符「ー」と小書き文字も1字として数えます。<b>円環交差数</b>は五十音を円環に並べ、読みの順に線で結んだときの交差回数です。いずれも登録時に自動計測し、値の更新は表記の修正時のみ行います。
  </p>
</div>

<footer class="dm-swiss__foot">
  <div>長い言葉のデータベース</div>
  <span><%= mock_stats[:words] %> entries</span>
</footer>
