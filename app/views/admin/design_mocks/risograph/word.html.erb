<% detail = mock_detail %>
<div class="dm-risograph__wrap">
  <%= render "admin/design_mocks/risograph/head" %>

  <nav class="dm-risograph__crumb">
    <% detail[:genres].each do |genre| %>
      <a href="#"><%= genre %></a>
    <% end %>
  </nav>

  <h1 class="dm-risograph__title"><%= detail[:surface] %></h1>
  <div class="dm-risograph__titleyomi"><%= detail[:reading] %></div>

  <div class="dm-risograph__chips">
    <span class="is-hot">読み <%= detail[:length] %> もじ</span>
    <span>交差 <%= detail[:crossing] %> 回</span>
    <span><%= detail[:part_of_speech] %></span>
    <span><%= detail[:origin] %></span>
  </div>

  <div class="dm-risograph__layout">
    <div class="dm-risograph__main">
      <nav class="dm-risograph__toc">
        <span>もくじ</span>
        <% mock_toc.each do |anchor, label| %>
          <a href="#<%= anchor %>"><%= label %></a>
        <% end %>
      </nav>

      <section class="dm-risograph__section" id="meaning">
        <h2 class="dm-risograph__h2">意味<span>語義 1 件</span></h2>
        <p class="dm-risograph__meaning"><%= detail[:summary] %></p>
        <div class="dm-risograph__box">
          <span class="dm-risograph__boxnum">語義 01</span>
          <p class="dm-risograph__meaning"><%= detail[:meaning] %></p>
        </div>
      </section>

      <section class="dm-risograph__section" id="data">
        <h2 class="dm-risograph__h2">言語データ<span>じどう計測</span></h2>
        <table class="dm-risograph__props">
          <tbody>
            <% mock_properties.each do |label, value| %>
              <tr>
                <th scope="row"><%= label %></th>
                <td><%= value %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </section>

      <section class="dm-risograph__section" id="related">
        <h2 class="dm-risograph__h2">関連する語<span>5 件</span></h2>
        <% mock_related_groups.each do |group| %>
          <div class="dm-risograph__relgroup">
            <div class="dm-risograph__rellabel"><%= group[:label] %></div>
            <div class="dm-risograph__rellist">
              <% group[:words].each do |word| %>
                <a href="#"><%= word.surface %></a>
              <% end %>
            </div>
          </div>
        <% end %>
      </section>

      <section class="dm-risograph__section" id="source">
        <h2 class="dm-risograph__h2">出典・更新<span>No. 1408</span></h2>
        <p class="dm-risograph__note">
          読みは辞書と出版社の表記で確認したもの。<b>円環交差数</b>は五十音を円環に並べ、読みの順に線で結んだときの交差回数。<br>
          最終更新 <%= detail[:updated_on] %>／データは CC BY 4.0。
        </p>
      </section>
    </div>

    <aside>
      <div class="dm-risograph__infobox">
        <h3>この語のデータ</h3>
        <dl>
          <% mock_infobox.each do |label, value| %>
            <div>
              <dt><%= label %></dt>
              <dd><%= value %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    </aside>
  </div>

  <nav class="dm-risograph__pager">
    <a href="#"><span>← まえ（15もじ）</span>天上天下唯我独尊</a>
    <a href="#"><span>つぎ（14もじ）→</span>栴檀は双葉より芳し</a>
  </nav>
</div>
