<% today = mock_words.first %>
<div class="dm-measure__wrap">
  <%= render "admin/design_mocks/measure/head" %>

  <section class="dm-measure__hero">
    <div>
      <div class="dm-measure__eyebrow">本日の測定対象</div>
      <h1 class="dm-measure__word"><a href="#"><%= today.surface %></a></h1>
      <div class="dm-measure__yomi"><%= today.reading %></div>
    </div>
    <div>
      <div class="dm-measure__gauge">
        <% today.length.times do %><i></i><% end %>
      </div>
      <div class="dm-measure__readout">
        <b><%= today.length %></b>
        <small>MORA</small>
      </div>
    </div>
  </section>

  <div class="dm-measure__search">
    <span>言葉・読み・意味から検索する</span>
    <b>検索</b>
  </div>

  <dl class="dm-measure__stats">
    <div class="dm-measure__stat"><b><%= mock_stats[:words] %></b><span>収録語</span></div>
    <div class="dm-measure__stat"><b><%= mock_stats[:senses] %></b><span>語義</span></div>
    <div class="dm-measure__stat"><b><%= mock_stats[:average] %></b><span>平均文字数</span></div>
    <div class="dm-measure__stat"><b><%= mock_stats[:max] %></b><span>最長</span></div>
  </dl>

  <div class="dm-measure__sectitle"><span>このデータベースについて</span></div>
  <p class="dm-measure__note">
    読みが<b>10文字以上</b>の日本語だけを集めて記録しています。すべての語に読み・ジャンル・語種・品詞・言語的特徴を付与し、長さや音の並びから引けるようにしています。
  </p>

  <div class="dm-measure__sectitle"><span>引き方</span></div>
  <div class="dm-measure__entries">
    <% mock_entry_points.each do |entry| %>
      <a class="dm-measure__entry" href="#">
        <span><%= entry[:meta] %></span>
        <b><%= entry[:title] %></b>
        <p><%= entry[:desc] %></p>
      </a>
    <% end %>
  </div>

  <div class="dm-measure__sectitle">
    <span>計測記録／新着</span>
    <a href="#">すべての記録 →</a>
  </div>

  <table class="dm-measure__table">
    <thead>
      <tr>
        <th>№</th>
        <th>言葉</th>
        <th>読み</th>
        <th>計測</th>
        <th>字</th>
      </tr>
    </thead>
    <tbody>
      <% mock_words.take(7).each_with_index do |word, index| %>
        <tr>
          <td class="num"><%= format("%02d", index + 1) %></td>
          <td><a href="#"><%= word.surface %></a></td>
          <td class="yomi"><%= word.reading %></td>
          <td class="bar"><i style="width: <%= (word.length / 16.0 * 100).round %>%"></i></td>
          <td class="len"><%= word.length %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
