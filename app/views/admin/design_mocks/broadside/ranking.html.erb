<% max_count = mock_distribution.map(&:last).max %>
<%= render "admin/design_mocks/broadside/head" %>

<div class="dm-broadside__body">
  <h1 class="dm-broadside__ranktitle">読みが長い順</h1>
  <p class="dm-broadside__ranksub">収録 <%= mock_stats[:words] %> 語のうち、読みが16字に達するのはわずか6語。上位はほぼ成句と作品名が占める。</p>

  <div class="dm-broadside__idx" style="padding-top: 40px">並び順を選ぶ</div>
  <div class="dm-broadside__kinds" style="margin-top: 14px">
    <% mock_ranking_kinds.each_with_index do |kind, index| %>
      <a class="dm-broadside__kind<%= " is-on" if index.zero? %>" href="#">
        <b><%= kind[:label] %></b>
        <span><%= kind[:note] %></span>
      </a>
    <% end %>
  </div>

  <div class="dm-broadside__ranklist">
    <% mock_words.take(6).each_with_index do |word, index| %>
      <a class="dm-broadside__rankrow" href="#">
        <span class="rk"><%= index + 1 %></span>
        <span class="nm"><%= word.surface %><span class="yo"><%= word.reading %></span></span>
        <span class="vl"><%= word.length %><small>MOJI</small></span>
      </a>
    <% end %>
  </div>

  <div class="dm-broadside__idx" style="padding-top: 44px">円環交差数が多い順</div>
  <div class="dm-broadside__ranklist">
    <% mock_crossing_ranking.take(4).each_with_index do |word, index| %>
      <a class="dm-broadside__rankrow" href="#">
        <span class="rk"><%= index + 1 %></span>
        <span class="nm"><%= word.surface %><span class="yo"><%= word.reading %></span></span>
        <span class="vl"><%= word.crossing %><small>CROSS</small></span>
      </a>
    <% end %>
  </div>

  <div class="dm-broadside__idx" style="padding-top: 44px">読みの文字数の分布</div>
  <div class="dm-broadside__bars">
    <% mock_distribution.each do |_length, count| %>
      <div class="<%= "is-low" if count < 50 %>">
        <b><%= count %></b>
        <i style="height: <%= (count.to_f / max_count * 86).round %>%"></i>
      </div>
    <% end %>
  </div>
  <div class="dm-broadside__barsax">
    <% mock_distribution.each do |length, _count| %>
      <span><%= length %></span>
    <% end %>
  </div>

  <div class="dm-broadside__idx" style="padding-top: 44px">計測方法</div>
  <p class="dm-broadside__note" style="padding-top: 12px">
    <b>読みの文字数</b>はカタカナ表記の字数で、長音符「ー」と小書き文字も1字として数えます。<b>円環交差数</b>は五十音を円環に並べ、読みの順に線で結んだときの交差回数です。いずれも登録時に自動計測し、値の更新は表記の修正時のみ行います。
  </p>
</div>
