<% max_count = mock_distribution.map(&:last).max %>
<div class="dm-neobrutalism__wrap">
  <%= render "admin/design_mocks/neobrutalism/head" %>

  <section class="dm-neobrutalism__ranktitle">
    <h1>読みが長い順ランキング</h1>
    <p>収録 <%= mock_stats[:words] %> 語を読みの文字数で並べた。16文字に届くのは全体で6語だけ。</p>
  </section>

  <div class="dm-neobrutalism__kinds">
    <% mock_ranking_kinds.each_with_index do |kind, index| %>
      <a class="dm-neobrutalism__kind<%= " is-on" if index.zero? %>" href="#">
        <b><%= kind[:label] %></b>
        <span><%= kind[:note] %></span>
      </a>
    <% end %>
  </div>

  <div class="dm-neobrutalism__seclabel">読みが長い順</div>
  <div class="dm-neobrutalism__rank">
    <% mock_words.take(6).each_with_index do |word, index| %>
      <a class="dm-neobrutalism__rankrow" href="#">
        <span class="rk"><%= index + 1 %></span>
        <span class="nm"><%= word.surface %><small><%= word.reading %></small></span>
        <span class="vl"><%= word.length %></span>
      </a>
    <% end %>
  </div>

  <div class="dm-neobrutalism__seclabel">円環交差数が多い順</div>
  <div class="dm-neobrutalism__rank">
    <% mock_crossing_ranking.take(3).each_with_index do |word, index| %>
      <a class="dm-neobrutalism__rankrow" href="#">
        <span class="rk"><%= index + 1 %></span>
        <span class="nm"><%= word.surface %><small>円環交差数</small></span>
        <span class="vl"><%= word.crossing %></span>
      </a>
    <% end %>
  </div>

  <section class="dm-neobrutalism__dist">
    <h3>読みの文字数ごとの収録数</h3>
    <div class="dm-neobrutalism__bars">
      <% mock_distribution.each do |_length, count| %>
        <div class="<%= "is-low" if count < 50 %>">
          <b><%= count %></b>
          <i style="height: <%= (count.to_f / max_count * 84).round %>%"></i>
        </div>
      <% end %>
    </div>
    <div class="dm-neobrutalism__barsax">
      <% mock_distribution.each do |length, _count| %>
        <span><%= length %></span>
      <% end %>
    </div>
  </section>

  <div class="dm-neobrutalism__seclabel">計測方法</div>
  <p class="dm-neobrutalism__note">
    <b>読みの文字数</b>はカタカナ表記の字数で、長音符「ー」と小書き文字も1字として数えます。<b>円環交差数</b>は五十音を円環に並べ、読みの順に線で結んだときの交差回数です。いずれも登録時に自動計測しています。
  </p>
</div>
