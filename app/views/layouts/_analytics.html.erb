<%# GA4(Issue 19)。測定IDは環境変数 GA4_MEASUREMENT_ID。未設定なら何も出力しない。
    Turbo Drive は遷移がフルロードでないため、既定の page_view では2ページ目以降が
    計測されない。send_page_view:false にして turbo:load ごとに page_view を送る。 %>
<% if analytics_enabled? %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= u ga_measurement_id %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= j ga_measurement_id %>', { send_page_view: false });
    document.addEventListener('turbo:load', function(event) {
      gtag('event', 'page_view', {
        page_location: (event.detail && event.detail.url) || window.location.href,
        page_title: document.title
      });
    });
  </script>
<% end %>
