<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# サーチコンソール所有権確認(任意・環境変数。DNS 確認が使えないとき用。Issue 19) %>
    <% if google_site_verification %><meta name="google-site-verification" content="<%= google_site_verification %>"><% end %>
    <% if bing_site_verification %><meta name="msvalidate.01" content="<%= bing_site_verification %>"><% end %>
    <%= render "layouts/analytics" %>

    <%# 検索・SNS・LLM 向けのメタ情報(Issue 14)。値はヘルパーで一元化 %>
    <meta name="description" content="<%= page_description %>">
    <link rel="canonical" href="<%= canonical_url %>">
    <meta property="og:type" content="<%= page_og_type %>">
    <meta property="og:site_name" content="<%= t("layouts.brand") %>">
    <meta property="og:locale" content="ja_JP">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:image" content="<%= page_og_image %>">
    <%# 寸法は既定画像 og-default.png(1200×630)のもの。content_for(:og_image) で
        別画像に差し替える場合は寸法もヘルパー化して連動させること %>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="<%= t("layouts.og_image_alt") %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <%# 解禁前は全ページ noindex、解禁後はページ個別の指定(Issue 43 / Issue 17) %>
    <% if (robots = page_robots).present? %>
      <meta name="robots" content="<%= robots %>">
    <% end %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon.ico" sizes="32x32">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# 新着単語の Atom フィード(autodiscovery。Issue 28) %>
    <%= auto_discovery_link_tag :atom, words_path(format: :atom), title: t("words.feed.title") %>

    <%# 見出し用の明朝のみ web フォントで読む(本文は OS 標準ゴシック。docs/design.md §2)。
        display=swap に加え、CSS 自体もレンダーブロッキングにしない: media="print" で
        描画を止めずに読み込み、完了後に onload で全メディアへ適用する(モバイルの LCP 対策)。
        JS 無効環境では noscript 側の通常読み込みにフォールバックする。 %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500&family=Shippori+Mincho:wght@500;600&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500&family=Shippori+Mincho:wght@500;600&display=swap"></noscript>

    <%# モバイルのブラウザ UI の色。既定値はライトの --bg で、実際の値は
        直後のスクリプトと theme コントローラが CSS のトークンから読んで上書きする %>
    <meta name="theme-color" content="#faf8f4">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <%# ダークモードの復元(docs/design.md §9)。手動で選んだテーマを body の描画前に
        当てないと、一瞬ライトが見えてから暗転する。Stimulus の起動を待てないので
        ここだけインラインで実行する。CSS 読み込みの後に置いてトークンを参照する %>
    <%= javascript_tag nonce: true do %>
      (function () {
        try {
          var stored = window.localStorage.getItem("theme");
          if (stored === "dark" || stored === "light") {
            document.documentElement.dataset.theme = stored;
          }
        } catch (error) {
          // localStorage が使えない環境では OS 設定に従う
        }
        var themeColor = document.querySelector('meta[name="theme-color"]');
        if (themeColor) {
          themeColor.content =
            getComputedStyle(document.documentElement).getPropertyValue("--bg").trim();
        }
      })();
    <% end %>

    <%= javascript_importmap_tags %>

    <%# サイト自身と検索アクションの構造化データ(Issue 16) %>
    <%= website_json_ld %>
  </head>

  <body>
    <%= render "shared/header" %>
    <%# 管理画面だけに出す共通サブナビ(Issue 35) %>
    <%= render "admin/nav" if admin_page? %>

    <main class="container">
      <%# フラッシュはここで一元表示する(各ビューでは表示しない) %>
      <% if flash[:notice] %>
        <p class="flash flash--notice"><%= icon "check_circle" %><%= flash[:notice] %></p>
      <% end %>
      <% if flash[:alert] %>
        <p class="flash flash--alert"><%= icon "warning_circle" %><%= flash[:alert] %></p>
      <% end %>

      <%= yield %>
    </main>

    <%# 奥付。紙の色のまま細罫で仕切り、リンクは細いタイポグラフィで静かに並べる %>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__about">
          <p class="site-footer__brand"><%= t("layouts.brand") %></p>
          <p class="site-footer__desc"><%= t("layouts.footer.about") %></p>
          <nav class="site-footer__nav">
            <%= link_to about_path, class: "icon-label" do %><%= t("layouts.footer.more") %><%= icon "arrow_right" %><% end %>
          </nav>
        </div>

        <div>
          <h2 class="site-footer__col-title"><%= t("layouts.footer.col_search") %></h2>
          <nav class="site-footer__nav" aria-label="<%= t("layouts.footer.nav_label") %>">
            <%= link_to t("layouts.nav.words"), words_path %>
            <%= link_to t("layouts.nav.genres"), genres_path %>
            <%= link_to t("layouts.nav.browse"), browse_path %>
            <%= link_to t("layouts.nav.advanced_search"), search_path %>
            <%= link_to t("layouts.footer.random"), random_words_path %>
          </nav>
        </div>

        <div>
          <h2 class="site-footer__col-title"><%= t("layouts.footer.col_data") %></h2>
          <nav class="site-footer__nav">
            <%= link_to t("layouts.nav.ranking"), rankings_path %>
            <%= link_to t("layouts.nav.stats"), stats_path %>
          </nav>
        </div>

        <div>
          <h2 class="site-footer__col-title"><%= t("layouts.footer.col_site") %></h2>
          <nav class="site-footer__nav">
            <%= link_to t("layouts.nav.about"), about_path %>
            <%= link_to t("layouts.nav.privacy"), privacy_path %>
            <% if authenticated? %>
              <%= link_to t("layouts.nav.admin"), admin_words_path %>
            <% else %>
              <%= link_to t("layouts.footer.admin_login"), new_session_path %>
            <% end %>
          </nav>
        </div>
      </div>
      <div class="site-footer__bottom">
        <div class="site-footer__bottom-inner"><%= t("layouts.footer.copyright", year: Date.current.year) %></div>
      </div>
    </footer>
  </body>
</html>
