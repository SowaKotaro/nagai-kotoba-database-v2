<%# ジャンル階層フィルタ(ドロップダウンの代替)。大→中→小を段階表示し、任意の階層を選べる。
    選んだ節点の id を hidden の genre_id に書き込む。チップは全階層をサーバ側で描画済み。 %>
<fieldset class="chips-field">
  <legend class="field-legend"><%= WordSense.human_attribute_name(:genre) %></legend>

  <div class="genre-filter" data-controller="genre-filter">
    <%= hidden_field_tag :genre_id, @search.genre_id, data: { genre_filter_target: "value" } %>

    <% roots = @genres_by_parent[nil] || [] %>
    <div class="genre-filter__level">
      <% roots.each do |large| %>
        <button type="button" class="genre-chip" aria-pressed="false"
                data-genre-filter-target="chip" data-level="large" data-genre-id="<%= large.id %>"
                data-action="genre-filter#select"><%= large.name %></button>
      <% end %>
    </div>

    <% roots.each do |large| %>
      <% mediums = @genres_by_parent[large.id] || [] %>
      <% if mediums.any? %>
        <div class="genre-filter__level" data-genre-filter-target="group" data-level="medium" data-parent="<%= large.id %>" hidden>
          <% mediums.each do |medium| %>
            <button type="button" class="genre-chip" aria-pressed="false"
                    data-genre-filter-target="chip" data-level="medium" data-genre-id="<%= medium.id %>"
                    data-action="genre-filter#select"><%= medium.name %></button>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <% roots.each do |large| %>
      <% (@genres_by_parent[large.id] || []).each do |medium| %>
        <% smalls = @genres_by_parent[medium.id] || [] %>
        <% if smalls.any? %>
          <div class="genre-filter__level" data-genre-filter-target="group" data-level="small" data-parent="<%= medium.id %>" hidden>
            <% smalls.each do |small| %>
              <button type="button" class="genre-chip" aria-pressed="false"
                      data-genre-filter-target="chip" data-level="small" data-genre-id="<%= small.id %>"
                      data-action="genre-filter#select"><%= small.name %></button>
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</fieldset>
