<% content_for :title, t("searches.title") %>
<%# 検索フォームはインデックス不要(結果は /words 側に集約。Issue 17) %>
<% content_for :robots, "noindex,follow" %>

<%= render "shared/breadcrumbs", items: [ [ t("layouts.breadcrumbs_home"), root_path ], [ t("searches.title"), nil ] ] %>

<h1 class="page-title"><%= t("searches.title") %></h1>

<%= form_with url: search_path, method: :get, data: { turbo_action: "advance" }, class: "search-form" do %>
  <div class="field">
    <%= label_tag :q, class: "field-legend" do %><%= icon "magnifying_glass" %><%= t("searches.q_label") %><% end %>
    <%= text_field_tag :q, @search.q %>
  </div>

  <%# 読みの文字数: 二つまみスライダー(10〜30)。上限30は「以上」。 %>
  <fieldset class="slider-field">
    <legend class="field-legend"><%= icon "ruler" %><%= t("searches.reading_length") %></legend>
    <div class="length-slider" data-controller="range-slider"
         data-range-slider-min-value="10" data-range-slider-max-value="30">
      <p class="length-slider__message" data-range-slider-target="message"></p>
      <div class="length-slider__track" data-range-slider-target="track">
        <input type="range" min="10" max="30" value="<%= @search.reading_length_min || 10 %>"
               class="length-slider__thumb" data-range-slider-target="minThumb"
               data-action="input->range-slider#input" aria-label="<%= t('searches.reading_length_min') %>">
        <input type="range" min="10" max="30" value="<%= @search.reading_length_max || 30 %>"
               class="length-slider__thumb" data-range-slider-target="maxThumb"
               data-action="input->range-slider#input" aria-label="<%= t('searches.reading_length_max') %>">
      </div>
      <%= hidden_field_tag :reading_length_min, @search.reading_length_min, data: { range_slider_target: "minField" } %>
      <%= hidden_field_tag :reading_length_max, @search.reading_length_max, data: { range_slider_target: "maxField" } %>
    </div>
  </fieldset>

  <%= render "kana_grid", name: "first_char", selected: @search.first_char,
        legend: t("searches.first_char"), legend_icon: "skip_back" %>
  <%= render "kana_grid", name: "last_char", selected: @search.last_char,
        legend: t("searches.last_char"), legend_icon: "skip_forward" %>

  <%= render "genre_filter" %>

  <%= render "check_chips", name: "part_of_speech_id", collection: @parts_of_speech,
        selected: @search.part_of_speech_id, legend: WordSense.human_attribute_name(:part_of_speech),
        legend_icon: "article" %>
  <%= render "check_chips", name: "entity_type_id", collection: @entity_types,
        selected: @search.entity_type_id, legend: WordSense.human_attribute_name(:entity_type),
        legend_icon: "cube" %>

  <%= render "check_chips", name: "word_origin_id", collection: @word_origins,
        selected: @search.word_origin_id, legend: t("searches.word_origin"),
        legend_icon: "translate" %>

  <%= render "check_chips", name: "linguistic_feature_id", collection: @linguistic_features,
        selected: @search.linguistic_feature_id, legend: t("searches.linguistic_feature"),
        legend_icon: "pen_nib" %>

  <%# 母音パターン検索: 読みをカナで入れると母音の並び(例 ououaa)で押韻検索する %>
  <div class="field">
    <%= label_tag :vowel_reading, class: "field-legend" do %><%= icon "music_notes" %><%= t("searches.vowel_pattern") %><% end %>
    <%= text_field_tag :vowel_reading, @search.vowel_reading,
          placeholder: "トウキョウタワー", autocomplete: "off" %>
    <p class="field-hint"><%= t("searches.vowel_pattern_hint") %></p>
  </div>

  <div class="field">
    <%= label_tag :rhythm_pattern, class: "field-legend" do %><%= icon "text_aa" %><%= t("searches.rhythm_pattern") %><% end %>
    <%= text_field_tag :rhythm_pattern, @search.rhythm_pattern, autocomplete: "off" %>
  </div>

  <div class="field char-type-field" data-controller="char-type"
       data-char-type-lower-value="<%= CharTypePattern::LOWER %>"
       data-char-type-upper-value="<%= CharTypePattern::UPPER %>">
    <%= label_tag :char_type_pattern, class: "field-legend" do %><%= icon "keyboard" %><%= t("searches.char_type_pattern") %><% end %>

    <%# 入力はキーボード風のキー(あ/ア/漢/1/A/a/@)と削除キー(⌫)だけ。手入力は受け付けず、
        押したキーの文字種が下の表示欄に並ぶ(組み立て中のパターンを見せる読み取り専用の欄)。
        「a」だけは大文字小文字トグル(Aa)が off のとき「A」に畳まれるので隠す。 %>
    <div class="char-type-keys">
      <% [ CharTypePattern::HIRAGANA, CharTypePattern::KATAKANA, CharTypePattern::KANJI,
           CharTypePattern::DIGIT, CharTypePattern::UPPER, CharTypePattern::LOWER,
           CharTypePattern::OTHER ].each do |char| %>
        <% lower_key = char == CharTypePattern::LOWER %>
        <%= tag.button char, type: "button", class: "char-type-key",
              hidden: (lower_key && !@search.char_type_case_sensitive?),
              data: { action: "char-type#append", char_type_char_param: char,
                      char_type_target: ("lowerKey" if lower_key) } %>
      <% end %>
      <button type="button" class="char-type-key char-type-key--backspace"
              data-action="char-type#remove"
              aria-label="<%= t('searches.char_type_backspace') %>">
        <%= icon "backspace" %>
      </button>
    </div>
    <%# 先頭に「>」のプロンプト。上のキーを押すと文字種が左に等幅で並ぶ。右端は VSCode 風の
        切替アイコン(text-aa=大文字小文字, 自作"ab"=完全/部分一致)。塗り(背景)= 厳密側が有効。
        切り替えた瞬間だけ状態ラベルを 3 秒フェード表示する(ホバーには依存しない)。 %>
    <div class="char-type-display">
      <span class="char-type-display__prompt" aria-hidden="true">&gt;</span>
      <span class="char-type-display__value" data-char-type-target="display"
            data-placeholder="<%= t('searches.char_type_console_placeholder') %>"><%= @search.char_type_pattern %></span>
      <span class="char-type-display__flags">
        <%# 大文字小文字トグル。切り替えを親の char-type へ伝え、「a」キーの表示を連動させる %>
        <span class="char-type-flag" data-controller="char-type-toggle"
              data-action="char-type-toggle:changed->char-type#caseSensitivityChanged">
          <%= hidden_field_tag :char_type_ignore_case, (@search.char_type_case_sensitive? ? "" : "1"),
                data: { char_type_toggle_target: "input" } %>
          <button type="button" class="char-type-flag__btn"
                  data-char-type-toggle-target="button" data-action="char-type-toggle#toggle"
                  data-title-strict="<%= t('searches.char_type_case_sensitive') %>"
                  data-title-relaxed="<%= t('searches.char_type_case_insensitive') %>"
                  aria-pressed="<%= @search.char_type_case_sensitive? %>"
                  aria-label="<%= @search.char_type_case_sensitive? ? t('searches.char_type_case_sensitive') : t('searches.char_type_case_insensitive') %>">
            <%= icon "text_aa" %>
          </button>
          <span class="char-type-flag__tip" data-char-type-toggle-target="tip" aria-hidden="true"></span>
        </span>
        <span class="char-type-flag" data-controller="char-type-toggle">
          <%= hidden_field_tag :char_type_partial, (@search.char_type_partial? ? "1" : ""),
                data: { char_type_toggle_target: "input" } %>
          <button type="button" class="char-type-flag__btn"
                  data-char-type-toggle-target="button" data-action="char-type-toggle#toggle"
                  data-title-strict="<%= t('searches.char_type_match_exact') %>"
                  data-title-relaxed="<%= t('searches.char_type_match_partial') %>"
                  aria-pressed="<%= !@search.char_type_partial? %>"
                  aria-label="<%= @search.char_type_partial? ? t('searches.char_type_match_partial') : t('searches.char_type_match_exact') %>">
            <%= icon "quote_ab" %>
          </button>
          <span class="char-type-flag__tip" data-char-type-toggle-target="tip" aria-hidden="true"></span>
        </span>
      </span>
    </div>
    <%= hidden_field_tag :char_type_pattern, @search.char_type_pattern, data: { char_type_target: "field" } %>
  </div>

  <div class="search-actions">
    <%= submit_tag t("searches.submit"), class: "btn btn--primary" %>
    <%# 条件をクリア: パラメータ無しの検索ページへ戻る(フォームが初期状態で再描画される) %>
    <%= link_to search_path, class: "search-clear icon-label" do %>
      <%= icon "x" %><%= t("searches.clear") %>
    <% end %>
  </div>
<% end %>
