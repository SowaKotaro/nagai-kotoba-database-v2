<% content_for :title, t("searches.title") %>

<%= render "shared/breadcrumbs", items: [ [ t("layouts.breadcrumbs_home"), root_path ], [ t("searches.title"), nil ] ] %>

<h1 class="page-title"><%= t("searches.title") %></h1>

<%= form_with url: search_path, method: :get, data: { turbo_action: "advance" }, class: "search-form" do %>
  <div class="field">
    <%= label_tag :q, t("searches.q_label"), class: "field-legend" %>
    <%= text_field_tag :q, @search.q %>
  </div>

  <%# 読みの文字数: 二つまみスライダー(10〜30)。上限30は「以上」。 %>
  <fieldset class="slider-field">
    <legend class="field-legend"><%= t("searches.reading_length") %></legend>
    <div class="length-slider" data-controller="range-slider"
         data-range-slider-min-value="10" data-range-slider-max-value="30">
      <p class="length-slider__message" data-range-slider-target="message"></p>
      <div class="length-slider__track" data-range-slider-target="track">
        <input type="range" min="10" max="30" value="<%= @search.reading_length_min || 10 %>"
               class="length-slider__thumb" data-range-slider-target="minThumb"
               data-action="input->range-slider#input" aria-label="<%= t('searches.reading_length_min') %>">
        <input type="range" min="10" max="30" value="<%= @search.reading_length_max || 30 %>"
               class="length-slider__thumb" data-range-slider-target="maxThumb"
               data-action="input->range-slider#input" aria-label="<%= t('searches.reading_length_max') %>">
      </div>
      <%= hidden_field_tag :reading_length_min, @search.reading_length_min, data: { range_slider_target: "minField" } %>
      <%= hidden_field_tag :reading_length_max, @search.reading_length_max, data: { range_slider_target: "maxField" } %>
    </div>
  </fieldset>

  <%= render "kana_grid", name: "first_char", selected: @search.first_char, legend: t("searches.first_char") %>
  <%= render "kana_grid", name: "last_char", selected: @search.last_char, legend: t("searches.last_char") %>

  <%= render "genre_filter" %>

  <%= render "check_chips", name: "part_of_speech_id", collection: @parts_of_speech,
        selected: @search.part_of_speech_id, legend: WordSense.human_attribute_name(:part_of_speech) %>
  <%= render "check_chips", name: "entity_type_id", collection: @entity_types,
        selected: @search.entity_type_id, legend: WordSense.human_attribute_name(:entity_type) %>

  <%= render "check_chips", name: "linguistic_feature_id", collection: @linguistic_features,
        selected: @search.linguistic_feature_id, legend: t("searches.linguistic_feature") %>

  <div class="field">
    <%= label_tag :rhythm_pattern, t("searches.rhythm_pattern"), class: "field-legend" %>
    <%= text_field_tag :rhythm_pattern, @search.rhythm_pattern %>
  </div>

  <div class="field" data-controller="char-type">
    <%= label_tag :char_type_pattern, t("searches.char_type_pattern"), class: "field-legend" %>
    <%# 入力キー。押すたびに対応する記号を入力欄の末尾へ追記する(削除は通常のテキスト編集で) %>
    <div class="char-type-keys">
      <% [ CharTypePattern::HIRAGANA, CharTypePattern::KATAKANA, CharTypePattern::KANJI,
           CharTypePattern::ALPHABET, CharTypePattern::OTHER ].each do |char| %>
        <button type="button" class="char-type-key" data-action="char-type#append"
                data-char-type-char-param="<%= char %>"><%= char %></button>
      <% end %>
    </div>
    <%= text_field_tag :char_type_pattern, @search.char_type_pattern, data: { char_type_target: "field" } %>
  </div>

  <%= submit_tag t("searches.submit"), class: "btn btn--primary" %>
<% end %>
