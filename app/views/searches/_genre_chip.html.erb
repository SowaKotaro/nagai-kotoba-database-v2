<%# ジャンル1件分のチップ(チェックボックス)。
    locals: genre(対象), parent(親ジャンル。大分類は nil), selected(選択中idの文字列配列) %>
<label class="check-chip">
  <%= check_box_tag "genre_id[]", genre.id, selected.include?(genre.id.to_s), id: nil, class: "visually-hidden",
        data: { genre_filter_target: "box", parent: parent&.id,
                action: "change->genre-filter#toggle" } %>
  <span class="check-chip__face"><%= genre.name %></span>
</label>
