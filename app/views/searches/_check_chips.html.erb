<%# 一覧から複数選択するチップ(ドロップダウンの代替)。
    locals: name(パラメータ名), collection(name を持つマスタ), selected(選択中idの配列), legend %>
<fieldset class="chips-field">
  <legend class="field-legend"><%= legend %></legend>
  <div class="check-chips">
    <% selected_ids = selected.map(&:to_s) %>
    <% collection.each do |item| %>
      <label class="check-chip">
        <%= check_box_tag "#{name}[]", item.id, selected_ids.include?(item.id.to_s), id: nil, class: "visually-hidden" %>
        <span class="check-chip__face"><%= item.name %></span>
      </label>
    <% end %>
  </div>
</fieldset>
