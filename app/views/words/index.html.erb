<%#
  インデックス方針(Issue 17):
  - 単一の対象ファセット(ジャンル/品詞/エンティティ/語種/先頭文字) 1つ かつ 1ページ目 → index + 動的見出し
  - 素の一覧の1ページ目 → index
  - それ以外(複数条件・キーワード・2ページ目以降) → noindex,follow
  canonical は重複を避けるため常に正規化した自身を指す。
%>
<% heading = facet_heading(@search) %>
<% page_heading = heading || t("words.index.title") %>
<%# 並び替え(sort)はコンテンツが同じ順列違いなので、既定順のときだけインデックスを許可する %>
<% indexable = @page == 1 && @sort.default? && (@search.indexable_facet.present? || !@search.conditions?) %>
<% content_for :robots, "noindex,follow" unless indexable %>
<% content_for :canonical_path, canonical_index_path(@search, @page) %>
<% content_for :title, page_heading %>
<% content_for :description,
     heading ? t("words.index.facet_description", label: heading) : t("words.index.description") %>

<%= render "shared/breadcrumbs", items: [ [ t("layouts.breadcrumbs_home"), root_path ], [ page_heading, nil ] ] %>

<h1 class="page-title"><%= page_heading %></h1>

<% conditions = applied_search_conditions(@search) %>
<% if conditions.any? %>
  <div class="active-facet">
    <%= icon "funnel" %>
    <ul class="condition-list">
      <% conditions.each do |label, value| %>
        <li class="condition-chip">
          <span class="condition-chip__label"><%= label %></span>
          <span class="condition-chip__value"><%= value %></span>
        </li>
      <% end %>
    </ul>
    <%= link_to search_path(request.query_parameters.except("page")), class: "active-facet__edit icon-label" do %>
      <%= icon "magnifying_glass" %><%= t("words.index.edit_conditions") %>
    <% end %>
    <%= link_to words_path, class: "active-facet__clear icon-label" do %>
      <%= icon "x" %><%= t("words.index.clear_filter") %>
    <% end %>
  </div>
<% end %>

<div class="entry-toolbar">
  <p class="entry-count"><%= t("words.index.total", count: @total_count) %></p>

  <% if @words.any? %>
    <div class="entry-toolbar__controls">
      <%# シャッフルは並び順ではなく「引き直す」操作なので、セレクタから外してボタンで置く。
          押すたびに新しいシードが振られ、並びを引き直せる %>
      <%= link_to shuffle_words_path, class: "btn btn--sm entry-toolbar__shuffle" do %>
        <%= icon "shuffle" %><%= t("words.index.shuffle") %>
      <% end %>

      <%# 並び順。絞り込み条件は hidden で引き継ぎ、select 変更で即送信(JS 無効時は noscript のボタン) %>
      <%= form_with url: words_path, method: :get, class: "sort-form", data: { controller: "auto-submit" } do %>
        <% request.query_parameters.except("page", "sort", "seed").each do |key, value| %>
          <% Array(value).each do |item| %>
            <%= hidden_field_tag(value.is_a?(Array) ? "#{key}[]" : key, item, id: nil) %>
          <% end %>
        <% end %>
        <label class="sort-form__label" for="sort"><%= icon "arrows_down_up" %><%= t("words.index.sort.label") %></label>
        <%= select_tag :sort,
              options_for_select(WordSort::SELECTABLE_KEYS.map { |key| [ t("words.index.sort.options.#{key}"), key ] },
                                 @sort.key),
              class: "sort-form__select",
              data: { action: "change->auto-submit#submit" } %>
        <noscript><%= submit_tag t("words.index.sort.apply"), class: "btn btn--sm", name: nil %></noscript>
      <% end %>
    </div>
  <% end %>
</div>

<% if @words.empty? %>
  <%# 絞り込み結果が 0 件のときは「DB が空」ではなく「条件に一致なし」と伝える(誤解防止)。
      条件を外す導線は上の active-facet(絞り込みを解除)が担う。
      text: の完全一致検証に余分な空白が入らないよう、あえて1行で組む。 %>
  <p class="empty-note"><%= icon "binoculars" %><%= @search.conditions? ? t("words.index.empty_filtered") : t("words.index.empty") %></p>
<% else %>
  <div class="entry-list">
    <%= render partial: "words/entry_row", collection: @words, as: :word %>
  </div>

  <%= render "pagination" %>
<% end %>
