<%#
  インデックス方針(Issue 17):
  - 単一の対象ファセット(ジャンル/品詞/エンティティ/語種/先頭文字) 1つ かつ 1ページ目 → index + 動的見出し
  - 素の一覧の1ページ目 → index
  - それ以外(複数条件・キーワード・2ページ目以降) → noindex,follow
  canonical は重複を避けるため常に正規化した自身を指す。
%>
<% heading = facet_heading(@search) %>
<% page_heading = heading || t("words.index.title") %>
<% indexable = @page == 1 && (@search.indexable_facet.present? || !@search.conditions?) %>
<% content_for :robots, "noindex,follow" unless indexable %>
<% content_for :canonical_path, canonical_index_path(@search, @page) %>
<% content_for :title, page_heading %>
<% content_for :description, t("words.index.facet_description", label: heading) if heading %>

<%= render "shared/breadcrumbs", items: [ [ t("layouts.breadcrumbs_home"), root_path ], [ page_heading, nil ] ] %>

<h1 class="page-title"><%= page_heading %></h1>

<% conditions = applied_search_conditions(@search) %>
<% if conditions.any? %>
  <div class="active-facet">
    <%= icon "funnel" %>
    <ul class="condition-list">
      <% conditions.each do |label, value| %>
        <li class="condition-chip">
          <span class="condition-chip__label"><%= label %></span>
          <span class="condition-chip__value"><%= value %></span>
        </li>
      <% end %>
    </ul>
    <%= link_to search_path(request.query_parameters.except("page")), class: "active-facet__edit icon-label" do %>
      <%= icon "magnifying_glass" %><%= t("words.index.edit_conditions") %>
    <% end %>
    <%= link_to words_path, class: "active-facet__clear icon-label" do %>
      <%= icon "x" %><%= t("words.index.clear_filter") %>
    <% end %>
  </div>
<% end %>

<p class="entry-count"><%= t("words.index.total", count: @total_count) %></p>

<% if @words.empty? %>
  <p class="empty-note"><%= t("words.index.empty") %></p>
<% else %>
  <div class="entry-list">
    <%= render partial: "words/entry_row", collection: @words, as: :word %>
  </div>

  <%= render "pagination" %>
<% end %>
