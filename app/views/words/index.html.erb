<% content_for :title, t("words.index.title") %>

<%= render "shared/breadcrumbs", items: [ [ t("layouts.breadcrumbs_home"), root_path ], [ t("words.index.title"), nil ] ] %>

<h1 class="page-title"><%= t("words.index.title") %></h1>
<p class="entry-count"><%= t("words.index.total", count: @total_count) %></p>

<% if @words.empty? %>
  <p class="empty-note"><%= t("words.index.empty") %></p>
<% else %>
  <div class="entry-list">
    <% @words.each do |word| %>
      <div class="entry-row">
        <div class="entry-row__main">
          <%= link_to word.surface, word_path(word), class: "entry-row__surface" %>
          <span class="entry-row__reading"><%= word.word_senses.map(&:reading).join("、") %></span>
        </div>
        <span class="entry-row__meta"><%= t("words.index.senses_count", count: word.word_senses.size) %></span>
      </div>
    <% end %>
  </div>

  <%= render "pagination" %>
<% end %>
