<% content_for :title, t("words.index.title") %>

<%= render "shared/breadcrumbs", items: [ [ t("layouts.breadcrumbs_home"), root_path ], [ t("words.index.title"), nil ] ] %>

<h1 class="page-title"><%= t("words.index.title") %></h1>

<% if @active_facet %>
  <p class="active-facet">
    <span class="active-facet__label"><%= @active_facet.first %></span>
    <span class="active-facet__value"><%= @active_facet.last %></span>
    <%= link_to t("words.index.clear_filter"), words_path, class: "active-facet__clear" %>
  </p>
<% end %>

<p class="entry-count"><%= t("words.index.total", count: @total_count) %></p>

<% if @words.empty? %>
  <p class="empty-note"><%= t("words.index.empty") %></p>
<% else %>
  <div class="entry-list">
    <%= render partial: "words/entry_row", collection: @words, as: :word %>
  </div>

  <%= render "pagination" %>
<% end %>
