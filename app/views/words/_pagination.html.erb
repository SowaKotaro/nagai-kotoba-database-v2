<nav class="pagination">
  <% if @page > 1 %>
    <%= link_to t("words.pagination.prev"), words_path(page: @page - 1) %>
  <% end %>

  <span><%= t("words.pagination.status", page: @page, total: @total_pages) %></span>

  <% if @page < @total_pages %>
    <%= link_to t("words.pagination.next"), words_path(page: @page + 1) %>
  <% end %>
</nav>
