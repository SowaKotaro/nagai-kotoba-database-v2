<% content_for :title, @word.surface %>
<%# 自己完結の定義文(Issue 18)。meta description(Issue 14)に流用する %>
<% lead = word_lead_sentence(@word) %>
<% content_for :description, lead if lead.present? %>
<% content_for :og_type, "article" %>
<%# 語義ごとの DefinedTerm(構造化データ。Issue 16) %>
<%= word_json_ld(@word) %>

<%= render "shared/breadcrumbs",
      items: [ [ t("layouts.breadcrumbs_home"), root_path ], [ t("words.index.title"), words_path ], [ @word.surface, nil ] ] %>

<header class="page-header">
  <p class="page-eyebrow">
    <span><%= t("words.show.headword") %></span>
    <span class="mono"><%= t("words.show.record_number", id: @word.id) %></span>
  </p>
  <%# 見出しの末尾にさりげない虫眼鏡。アプリ内検索ではなく Web 検索へ別タブで飛ばす。
      リンク内に空白を作ると下線だけが浮くので、ブロックではなく引数で渡す %>
  <h1 class="page-title"><%= @word.surface %><%= link_to icon("magnifying_glass"),
        web_search_url(@word.surface), class: "page-title__web-search",
        target: "_blank", rel: "noopener noreferrer external",
        aria: { label: t("words.show.web_search", surface: @word.surface) } %></h1>
  <p class="page-title-meta">
    <%= t("words.show.char_type_pattern") %>：<span class="mono"><%= @word.char_type_pattern %></span>
  </p>
  <%# 動的に組み立てる解説文。図鑑の説明欄のように、墨1px枠のパネルへ収める %>
  <% if lead.present? %>
    <figure class="word-flavor">
      <figcaption class="word-flavor__label mono"><%= t("words.show.flavor_label") %></figcaption>
      <p class="word-flavor__text"><%= lead %></p>
    </figure>
  <% end %>

  <%# シェア導線(Issue 30)。X共有 + URLコピー。アイコンはインラインSVG %>
  <% share_url = canonical_url %>
  <% x_href = "https://x.com/intent/post?" + { text: (lead.presence || @word.surface), url: share_url }.to_query %>
  <div class="share" data-controller="clipboard"
       data-clipboard-text-value="<%= share_url %>"
       data-clipboard-copied-label-value="<%= t('words.show.share.copied') %>">
    <%= link_to x_href, class: "share__btn", target: "_blank", rel: "noopener" do %>
      <%= icon "x_logo" %><span><%= t("words.show.share.x") %></span>
    <% end %>
    <button type="button" class="share__btn" data-action="clipboard#copy">
      <%= icon "link" %><span data-clipboard-target="label"><%= t("words.show.share.copy") %></span>
    </button>
  </div>
</header>

<% if @word.word_senses.empty? %>
  <p class="empty-note"><%= t("words.show.no_senses") %></p>
<% else %>
  <div class="sense-list">
    <% @word.word_senses.each.with_index(1) do |sense, number| %>
      <section class="sense-card">
        <span class="sense-card__number"><%= t("words.show.sense_number", number: format("%02d", number)) %></span>

        <%# 語義ごとの読みをグループルビで示す(読みは必ずテキスト。docs/design.md §5.2) %>
        <h2 class="sense-heading">
          <ruby><%= @word.surface %><rt><%= sense.reading %></rt></ruby>
        </h2>

        <%# 韻・母音パターンは検索対象ではなく、見出し語の直下にメタとして添える %>
        <p class="sense-heading-meta">
          <span><%= WordSense.human_attribute_name(:rhythm_pattern) %>：<span class="mono"><%= sense.rhythm_pattern %></span></span>
          <% if sense.vowel_pattern.present? %>
            <span><%= t("words.show.vowel_pattern") %>：<span class="mono"><%= sense.vowel_pattern %></span></span>
          <% end %>
        </p>

        <% if sense.meaning.present? %>
          <p class="sense-meaning"><%= sense.meaning %></p>
        <% end %>

        <p class="section-label"><%= t("words.show.features") %></p>
        <% if sense.word_sense_features.any? %>
          <ul class="annotations">
            <% sense.word_sense_features.each do |feature| %>
              <li class="annotation">
                <%# チップは同じ特徴の単語一覧へ、該当部分は朱ハイライト+読みルビ %>
                <%= link_to feature.linguistic_feature.name,
                      words_path(linguistic_feature_id: feature.linguistic_feature_id), class: "chip" %>
                <ruby class="annotation-target"><%= feature.target %><rt><%= feature.target_reading %></rt></ruby>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="sense-undefined"><%= t("words.show.undefined") %></p>
        <% end %>

        <dl class="sense-attrs">
          <%# 表示順: (言語学的特徴は上の注釈ブロック) → ジャンル → エンティティ → 品詞 →
              語種 → 文字数 → モーラ数 → 先頭文字 → 末尾文字 → 別表記。未登録は「未定義」を明示 %>
          <div class="sense-attrs__item sense-attrs__item--wide">
            <dt><%= WordSense.human_attribute_name(:genre) %></dt>
            <dd>
              <% if sense.genre %>
                <%# 各階層から単語一覧の絞り込みへ飛べるパンくず。末端は少し強調 %>
                <nav class="genre-path">
                  <% hierarchy = sense.genre.self_and_ancestors %>
                  <% hierarchy.each.with_index(1) do |genre, depth| %>
                    <% current = depth == hierarchy.size %>
                    <%= link_to genre.name, words_path(genre_id: genre.id),
                          class: ("genre-path__current" if current) %>
                    <% unless current %><span class="genre-path__sep">›</span><% end %>
                  <% end %>
                </nav>
              <% else %>
                <span class="sense-undefined"><%= t("words.show.undefined") %></span>
              <% end %>
            </dd>
          </div>

          <div class="sense-attrs__item">
            <dt><%= WordSense.human_attribute_name(:entity_type) %></dt>
            <dd>
              <% if sense.entity_type %>
                <%= link_to sense.entity_type.name,
                      words_path(entity_type_id: sense.entity_type_id), class: "tag" %>
              <% else %>
                <span class="sense-undefined"><%= t("words.show.undefined") %></span>
              <% end %>
            </dd>
          </div>

          <div class="sense-attrs__item">
            <dt><%= WordSense.human_attribute_name(:part_of_speech) %></dt>
            <dd>
              <% if sense.part_of_speech %>
                <%= link_to sense.part_of_speech.name,
                      words_path(part_of_speech_id: sense.part_of_speech_id), class: "tag" %>
              <% else %>
                <span class="sense-undefined"><%= t("words.show.undefined") %></span>
              <% end %>
            </dd>
          </div>

          <div class="sense-attrs__item">
            <dt><%= t("words.show.origins") %></dt>
            <dd>
              <% if sense.word_origins.any? %>
                <span class="tag-row">
                  <% sense.word_origins.each do |origin| %>
                    <%= link_to origin.name, words_path(word_origin_id: origin.id), class: "tag" %>
                  <% end %>
                </span>
              <% else %>
                <span class="sense-undefined"><%= t("words.show.undefined") %></span>
              <% end %>
            </dd>
          </div>

          <div class="sense-attrs__item">
            <dt><%= t("words.show.reading_length") %></dt>
            <dd><%= link_to t("words.show.chars", count: sense.reading_length),
                      words_path(reading_length: sense.reading_length), class: "tag" %></dd>
          </div>

          <% if sense.mora_count %>
            <div class="sense-attrs__item">
              <dt><%= t("words.show.mora_count") %></dt>
              <dd><%= link_to t("words.show.mora", count: sense.mora_count),
                        words_path(mora_count: sense.mora_count), class: "tag" %></dd>
            </div>
          <% end %>

          <div class="sense-attrs__item">
            <dt><%= t("words.show.first_char") %></dt>
            <dd><%= link_to sense.first_char, words_path(first_char: sense.first_char), class: "tag" %></dd>
          </div>

          <div class="sense-attrs__item">
            <dt><%= t("words.show.last_char") %></dt>
            <dd><%= link_to sense.last_char, words_path(last_char: sense.last_char), class: "tag" %></dd>
          </div>

          <div class="sense-attrs__item sense-attrs__item--wide">
            <dt><%= t("words.show.variants") %></dt>
            <dd>
              <% if sense.word_sense_variants.any? %>
                <ul class="variant-list">
                  <% sense.word_sense_variants.each do |variant| %>
                    <li><ruby><%= variant.surface %><rt><%= variant.reading %></rt></ruby></li>
                  <% end %>
                </ul>
              <% else %>
                <span class="sense-undefined"><%= t("words.show.undefined") %></span>
              <% end %>
            </dd>
          </div>
        </dl>
      </section>
    <% end %>
  </div>
<% end %>

<% if @related_word_groups.any? %>
  <section class="related">
    <h2 class="related__title"><%= t("words.show.related.title") %></h2>
    <% @related_word_groups.each do |group| %>
      <div class="related__group">
        <p class="section-label"><%= t("words.show.related.#{group.key}") %></p>
        <div class="entry-list">
          <%= render partial: "words/entry_row", collection: group.words, as: :word %>
        </div>
        <%= link_to words_path(group.facet_params), class: "related__more icon-label" do %>
          <%= t("words.show.related.more") %><%= icon "arrow_right" %>
        <% end %>
      </div>
    <% end %>
  </section>
<% end %>

<p>
  <%= link_to words_path, class: "back-link icon-label" do %>
    <%= icon "arrow_left" %><%= t("words.show.back") %>
  <% end %>
</p>
