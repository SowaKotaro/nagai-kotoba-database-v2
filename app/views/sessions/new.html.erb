<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
<%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>

<%= form_with url: session_path do |form| %>
  <%= form.text_field :username, required: true, autofocus: true, autocomplete: "username", placeholder: t("sessions.new.username_placeholder"), value: params[:username] %><br>
  <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: t("sessions.new.password_placeholder"), maxlength: 72 %><br>
  <%= form.submit t("sessions.new.submit") %>
<% end %>
