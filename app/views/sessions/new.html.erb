<% content_for :title, t("sessions.new.title") %>

<h1 class="page-title"><%= t("sessions.new.title") %></h1>

<%# フラッシュはレイアウトで一元表示される %>
<%= form_with url: session_path do |form| %>
  <div class="field">
    <%= form.text_field :username, required: true, autofocus: true, autocomplete: "username", placeholder: t("sessions.new.username_placeholder"), value: params[:username] %>
  </div>
  <div class="field">
    <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: t("sessions.new.password_placeholder"), maxlength: 72 %>
  </div>
  <%= form.submit t("sessions.new.submit"), class: "btn btn--primary" %>
<% end %>
