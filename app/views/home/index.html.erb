<%# ホーム: 主役は検索。見出し → 短い説明 → ページ最大の検索バー → 統計 → 3カラム。
    「今日の一語」は3カラムの1面に置き、検索より目立たせない。 %>
<%# <title> はタグライン付き、meta description は長めの専用文言(ヒーロー見出しとは別管理) %>
<% content_for :title, t("home.index.title_tagline") %>
<% content_for :description, t("home.index.meta_description") %>

<section class="hero">
  <h1 class="hero__title"><%= t("home.index.hero_title") %></h1>
  <p class="hero__lead"><%= t("home.index.description") %></p>

  <%= form_with url: words_path, method: :get, class: "hero-search" do %>
    <%= icon "magnifying_glass" %>
    <%= text_field_tag :q, nil, placeholder: t("home.index.search_placeholder"),
          class: "hero-search__input", aria: { label: t("searches.q_label") } %>
    <button type="submit" class="hero-search__submit"><%= t("layouts.search_submit") %></button>
  <% end %>

  <p class="hero__sub">
    <%= link_to search_path do %><%= t("home.index.advanced") %><%= icon "arrow_right" %><% end %>
  </p>
</section>

<dl class="stats-grid">
  <div class="stats-grid__item">
    <dt><%= t("home.index.stats.words") %></dt>
    <dd><%= number_with_delimiter(@word_count) %><span class="stats-grid__unit"><%= t("home.index.stats.words_unit") %></span></dd>
  </div>
  <div class="stats-grid__item">
    <dt><%= t("home.index.stats.senses") %></dt>
    <dd><%= number_with_delimiter(@sense_count) %><span class="stats-grid__unit"><%= t("home.index.stats.senses_unit") %></span></dd>
  </div>
  <div class="stats-grid__item">
    <dt><%= t("home.index.stats.genres") %></dt>
    <dd><%= number_with_delimiter(@genre_count) %><span class="stats-grid__unit"><%= t("home.index.stats.genres_unit") %></span></dd>
  </div>
  <%# 「長い言葉の」データベースであることが数字で分かる指標。語が無いうちは出さない %>
  <% if @average_reading_length %>
    <div class="stats-grid__item">
      <dt><%= t("home.index.stats.average_reading") %></dt>
      <dd><%= number_with_precision(@average_reading_length, precision: 1) %><span class="stats-grid__unit"><%= t("home.index.stats.average_reading_unit") %></span></dd>
    </div>
  <% end %>
</dl>

<%# 今日の一語は全幅の帯で1つだけ置く(3カラムに混ぜると中身が薄く縦に間延びするため)。
    ただし検索より目立たせないよう、見出し語はヒーローよりずっと小さく組む。 %>
<% if @featured_word %>
  <% featured_sense = @featured_word.word_senses.first %>
  <section class="home-featured">
    <%# 見出し行は下の2カラムと同じ組み(左にラベル、右端に導線) %>
    <div class="home-column__header">
      <h2 class="home-column__title"><%= icon "sparkle" %><%= t("home.index.featured") %></h2>
      <%= link_to word_path(@featured_word), class: "home-featured__more" do %>
        <%= t("home.index.featured_more") %><%= icon "arrow_right" %>
      <% end %>
    </div>
    <div class="home-featured__body">
      <div class="home-featured__headword">
        <%= link_to @featured_word.surface, word_path(@featured_word), class: "home-featured__word" %>
        <p class="home-featured__reading"><%= @featured_word.word_senses.map(&:reading).join("、") %></p>
      </div>
      <% if featured_sense&.meaning.present? %>
        <p class="home-featured__meaning"><%= truncate(featured_sense.meaning, length: 120) %></p>
      <% end %>
    </div>
  </section>
<% end %>

<div class="home-columns">
  <section class="home-column">
    <div class="home-column__header">
      <h2 class="home-column__title"><%= icon "bell_ringing" %><%= t("home.index.recent") %></h2>
      <%= link_to t("home.index.see_all"), words_path, class: "home-column__more" %>
    </div>
    <% @recent_words.each do |word| %>
      <%= link_to word_path(word), class: "home-column__item" do %>
        <span class="home-column__mark home-column__mark--new"><%= t("home.index.new_badge") %></span>
        <span class="home-column__body">
          <span class="home-column__word"><%= word.surface %></span>
          <span class="home-column__reading"><%= word.word_senses.first&.reading %></span>
        </span>
        <span class="home-column__meta"><%= l(word.created_at.to_date, format: :short) %></span>
      <% end %>
    <% end %>
  </section>

  <section class="home-column">
    <div class="home-column__header">
      <h2 class="home-column__title"><%= icon "crown" %><%= t("home.index.ranking") %></h2>
      <%= link_to t("home.index.see_ranking"), rankings_path, class: "home-column__more" %>
    </div>
    <% @longest_words.take(5).each_with_index do |word, index| %>
      <%= link_to word_path(word), class: "home-column__item" do %>
        <span class="home-column__mark"><%= index + 1 %></span>
        <span class="home-column__body">
          <span class="home-column__word"><%= word.surface %></span>
          <span class="home-column__reading"><%= word.word_senses.first&.reading %></span>
        </span>
        <% if (length = word.word_senses.first&.reading_length) %>
          <span class="home-column__meta"><%= t("words.index.char_count", count: length) %></span>
        <% end %>
      <% end %>
    <% end %>
  </section>
</div>
