<%# ホーム: サービスの顔。検索窓・収録statistics・新着で「データベース」であることを一目で伝える %>
<section class="hero">
  <h1 class="hero__title"><%= t("layouts.brand") %></h1>
  <p class="hero__lead"><%= t("home.index.description") %></p>

  <%= form_with url: search_path, method: :get, class: "hero-search" do %>
    <%= text_field_tag :q, nil, placeholder: t("home.index.search_placeholder"),
          class: "hero-search__input", aria: { label: t("searches.q_label") } %>
    <%= submit_tag t("home.index.search_submit"), class: "btn btn--primary" %>
  <% end %>
</section>

<dl class="stats-grid">
  <div class="stats-grid__item">
    <dt><%= t("home.index.stats.words") %></dt>
    <dd><%= number_with_delimiter(@word_count) %><span class="stats-grid__unit"><%= t("home.index.stats.words_unit") %></span></dd>
  </div>
  <div class="stats-grid__item">
    <dt><%= t("home.index.stats.senses") %></dt>
    <dd><%= number_with_delimiter(@sense_count) %><span class="stats-grid__unit"><%= t("home.index.stats.senses_unit") %></span></dd>
  </div>
  <div class="stats-grid__item">
    <dt><%= t("home.index.stats.genres") %></dt>
    <dd><%= number_with_delimiter(@genre_count) %><span class="stats-grid__unit"><%= t("home.index.stats.genres_unit") %></span></dd>
  </div>
</dl>

<section>
  <div class="section-header">
    <h2 class="section-heading"><%= t("home.index.recent") %></h2>
    <%= link_to t("home.index.see_all"), words_path, class: "section-header__more" %>
  </div>

  <% if @recent_words.empty? %>
    <p class="empty-note"><%= t("words.index.empty") %></p>
  <% else %>
    <div class="entry-list">
      <% @recent_words.each do |word| %>
        <div class="entry-row">
          <div class="entry-row__main">
            <%= link_to word.surface, word_path(word), class: "entry-row__surface" %>
            <span class="entry-row__reading"><%= word.word_senses.map(&:reading).join("、") %></span>
          </div>
          <span class="entry-row__meta"><%= t("words.index.senses_count", count: word.word_senses.size) %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
