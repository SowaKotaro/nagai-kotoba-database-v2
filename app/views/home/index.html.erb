<%# ホーム: 型見本の表紙。ステートメント → 今日の一語(巨大) → 探し方の導線 → 収録統計 → 新着
    (キーワード検索はヘッダーに常設しているため、ここには置かない) %>
<section class="hero">
  <h1 class="hero__lead"><%= t("home.index.description") %></h1>

  <% if @featured_word %>
    <div class="hero-featured">
      <p class="hero-featured__label"><%= icon "sparkle" %><%= t("home.index.featured") %></p>
      <%= link_to @featured_word.surface, word_path(@featured_word), class: "hero-featured__word" %>
      <p class="hero-featured__reading"><%= @featured_word.word_senses.map(&:reading).join("、") %></p>
    </div>
  <% end %>

  <%# 探し方の導線。墨1px枠のパネルを並べ、各検索ページへ誘う %>
  <nav class="hero-entries" aria-label="<%= t("home.index.entries.label") %>">
    <%= link_to genres_path, class: "hero-entry" do %>
      <%= icon "tag" %><span><%= t("home.index.entries.genres") %></span><%= icon "arrow_right", "hero-entry__arrow" %>
    <% end %>
    <%= link_to browse_path, class: "hero-entry" do %>
      <%= icon "grid_nine" %><span><%= t("home.index.entries.browse") %></span><%= icon "arrow_right", "hero-entry__arrow" %>
    <% end %>
    <%= link_to search_path, class: "hero-entry" do %>
      <%= icon "funnel" %><span><%= t("home.index.entries.search") %></span><%= icon "arrow_right", "hero-entry__arrow" %>
    <% end %>
  </nav>
</section>

<dl class="stats-grid">
  <div class="stats-grid__item">
    <dt><%= icon "books" %><%= t("home.index.stats.words") %></dt>
    <dd><%= number_with_delimiter(@word_count) %><span class="stats-grid__unit"><%= t("home.index.stats.words_unit") %></span></dd>
  </div>
  <div class="stats-grid__item">
    <dt><%= icon "book_open" %><%= t("home.index.stats.senses") %></dt>
    <dd><%= number_with_delimiter(@sense_count) %><span class="stats-grid__unit"><%= t("home.index.stats.senses_unit") %></span></dd>
  </div>
  <div class="stats-grid__item">
    <dt><%= icon "tag" %><%= t("home.index.stats.genres") %></dt>
    <dd><%= number_with_delimiter(@genre_count) %><span class="stats-grid__unit"><%= t("home.index.stats.genres_unit") %></span></dd>
  </div>
</dl>

<section>
  <div class="section-header">
    <h2 class="section-heading"><%= icon "bell_ringing" %><%= t("home.index.recent") %></h2>
    <%= link_to words_path, class: "section-header__more icon-label" do %>
      <%= t("home.index.see_all") %><%= icon "arrow_right" %>
    <% end %>
  </div>

  <% if @recent_words.empty? %>
    <p class="empty-note"><%= icon "binoculars" %><%= t("words.index.empty") %></p>
  <% else %>
    <div class="entry-list">
      <%= render partial: "words/entry_row", collection: @recent_words, as: :word %>
    </div>
  <% end %>
</section>
